<Window x:Class="Elgamal_Signature_CS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chữ Ký Số ElGamal — Nhóm 3 ANM-HaUI"
        Height="780" Width="980"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtEditable" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#90A4AE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="TxtReadonly" TargetType="TextBox">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="LblField" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#546E7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnTransfer" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel Margin="20,14" HorizontalAlignment="Center">
                <TextBlock Text="🔐 CHỮ KÝ SỐ ELGAMAL" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Chế độ: Sinh tự động siêu tốc &amp; Nhập thủ công đề bài | Nhóm 3" FontSize="11.5" Foreground="#90CAF9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" x:Name="tabMain" Margin="12,10,12,12" Background="White" BorderBrush="#CFD8DC">

            <TabItem FontSize="13" FontWeight="SemiBold" Padding="12,6" Header="🔑 Tạo Khóa">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,16">
                        <TextBlock Text="Sinh cặp khóa hoặc Nhập tham số bài tập toán" FontSize="15" FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Kích thước khóa tự động:" Style="{StaticResource LblField}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbKeySize" Width="170" SelectedIndex="1" VerticalAlignment="Center" Padding="6,4">
                                <ComboBoxItem Content="256-bit (Demo nhanh)"/>
                                <ComboBoxItem Content="512-bit (Khuyến nghị)"/>
                                <ComboBoxItem Content="1024-bit (Tối ưu mới)"/>
                            </ComboBox>
                            <Button Content="⚙ Tự Động Sinh" x:Name="btnGenerateKeys" Style="{StaticResource BtnPrimary}" Click="BtnGenerateKeys_Click" Margin="14,0,0,0"/>
                            <Button Content="📝 Áp Dụng Thủ Công" x:Name="btnApplyManual" Style="{StaticResource BtnPrimary}" Background="#E65100" Click="BtnApplyManual_Click" Margin="14,0,0,0"/>
                            <Button Content="💾 Lưu Cặp Khóa" x:Name="btnSaveKeys" Style="{StaticResource BtnTransfer}" Click="BtnSaveKeys_Click" Margin="14,0,0,0"/>
                        </StackPanel>

                        <Border Background="#E3F2FD" CornerRadius="7" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📢 THAM SỐ CÔNG KHAI (Nhập thủ công hoặc Sinh tự động)" FontWeight="Bold" Foreground="#1565C0" FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Text="q — Số nguyên tố (Mô-đun):" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtQ" Height="50" Style="{StaticResource TxtEditable}"/>

                                <TextBlock Text="a — Căn nguyên thủy mod q (g):" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtA" Height="34" Style="{StaticResource TxtEditable}"/>

                                <TextBlock Text="X_A — Khóa bí mật (Cần nhập để tạo Y_A thủ công):" Style="{StaticResource LblField}" Foreground="#B71C1C"/>
                                <TextBox x:Name="txtXA" Height="50" Style="{StaticResource TxtEditable}" Background="#FFF5F5"/>

                                <TextBlock Text="Y_A — Khóa công khai (Sẽ tự tính toán nếu bấm Áp Dụng Thủ Công):" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtYA" Height="50" Style="{StaticResource TxtReadonly}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="txtKeyStatus" FontStyle="Italic" Foreground="#2E7D32" FontWeight="Bold"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem FontSize="13" FontWeight="SemiBold" Padding="12,6" Header="✍ Ký Số">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,16">
                        <TextBlock Text="📝 Thông điệp cần ký (M - Chấp nhận nhập chuỗi hoặc số đề bài):" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtMsgSign" Height="70" Style="{StaticResource TxtEditable}"/>

                        <TextBlock Text="🎲 Tham số ngẫu nhiên k (Để trống nếu muốn sinh ngẫu nhiên tự động):" Style="{StaticResource LblField}" Foreground="#E65100"/>
                        <TextBox x:Name="txtKInput" Height="34" Style="{StaticResource TxtEditable}" Background="#FFF8E1"/>

                        <TextBlock Text="# Giá trị băm M hoặc mã SHA-256 số nguyên:" Style="{StaticResource LblField}" Foreground="#5C6BC0"/>
                        <TextBox x:Name="txtSignHash" Height="34" Style="{StaticResource TxtReadonly}" Foreground="#5C6BC0"/>

                        <Button Content="✍ Ký Thông Điệp" x:Name="btnSign" Style="{StaticResource BtnPrimary}" Click="BtnSign_Click" HorizontalAlignment="Center" Margin="0,14,0,14"/>

                        <Border Background="#E8F5E9" CornerRadius="7" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="📜 CHỮ KÝ SỐ ĐẦU RA" FontWeight="Bold" Foreground="#2E7D32" FontSize="13" Margin="0,0,0,10"/>
                                <TextBlock Grid.Row="1" Text="r = a^k mod q:" Style="{StaticResource LblField}"/>
                                <TextBox Grid.Row="2" x:Name="txtSignR" Height="34" Style="{StaticResource TxtReadonly}"/>
                                <TextBlock Grid.Row="3" Text="s = k⁻¹ · (M − X_A·r) mod (q−1):" Style="{StaticResource LblField}"/>
                                <TextBox Grid.Row="4" x:Name="txtSignS" Height="34" Style="{StaticResource TxtReadonly}"/>
                                <TextBlock Grid.Row="5" Text="✨ Chữ ký block dạng chuỗi gộp:" Style="{StaticResource LblField}"/>
                                <TextBox Grid.Row="6" x:Name="txtSignatureBlock" Height="40" Style="{StaticResource TxtReadonly}" Foreground="#1B5E20" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>
                        <Separator Margin="0,12"/>
                        <Button Content="💾 Lưu Chữ Ký Số (.sig)" x:Name="btnSaveSignature" Style="{StaticResource BtnTransfer}" Click="BtnSaveSignature_Click" HorizontalAlignment="Right"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem FontSize="13" FontWeight="SemiBold" Padding="12,6" Header="✅ Xác Thực">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="📂 Nạp Khóa Công Khai (.pub)" Style="{StaticResource BtnSecondary}" Click="BtnLoadPublicKey_Click" Margin="0,0,14,0"/>
                            <Button Content="📂 Nạp File Chữ Ký (.sig)" Style="{StaticResource BtnSecondary}" Click="BtnLoadSignatureFile_Click"/>
                        </StackPanel>
                        <TextBlock Text="📝 Thông điệp cần xác thực:" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtMsgVerify" Height="70" Style="{StaticResource TxtEditable}"/>
                        <TextBlock Text="r (Thành phần chữ ký):" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtVerifyR" Height="34" Style="{StaticResource TxtEditable}"/>
                        <TextBlock Text="s (Thành phần chữ ký):" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtVerifyS" Height="34" Style="{StaticResource TxtEditable}"/>
                        <Button Content="🔍 Xác Thực Chữ Ký" x:Name="btnVerify" Style="{StaticResource BtnPrimary}" Click="BtnVerify_Click" HorizontalAlignment="Left" Margin="0,14,0,14"/>
                        <Border Background="#F5F5F5" CornerRadius="7" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📊 CHI TIẾT KIỂM TRA TOÁN HỌC" FontWeight="Bold" Foreground="#37474F" FontSize="13" Margin="0,0,0,10"/>
                                <TextBox x:Name="txtVHash" Height="34" Style="{StaticResource TxtReadonly}" Margin="0,5"/>
                                <TextBox x:Name="txtVLHS" Height="34" Style="{StaticResource TxtReadonly}" Margin="0,5"/>
                                <TextBox x:Name="txtVRHS" Height="34" Style="{StaticResource TxtReadonly}" Margin="0,5"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="borderResult" CornerRadius="8" Padding="20" Background="#ECEFF1">
                            <TextBlock x:Name="txtResult" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Foreground="#78909C" Text="— Chưa xác thực —"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>