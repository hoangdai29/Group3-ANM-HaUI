<Window x:Class="Elgamal_Signature_CS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chữ Ký Số ElGamal — Nhóm 3 ANM-HaUI"
        Height="750" Width="980"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#ECEFF1">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1976D2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#546E7A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#607D8B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnTransfer" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TxtReadonly" TargetType="TextBox">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="LblField" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="Margin" Value="0,10,0,3"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565C0">
            <StackPanel Margin="20,14" HorizontalAlignment="Center">
                <TextBlock Text="🔐 CHỮ KÝ SỐ ELGAMAL"
                           FontSize="22" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Xác thực tính toàn vẹn của dữ liệu | Nhóm 3 – ANM-HaUI"
                           FontSize="11.5" Foreground="#90CAF9"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" x:Name="tabMain" Margin="12,10,12,12"
                    Background="White" BorderBrush="#CFD8DC">

            <TabItem FontSize="13" FontWeight="SemiBold" Padding="12,6">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔑" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="Tạo Khóa"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,16">
                        <TextBlock Text="Sinh cặp khóa ElGamal" FontSize="15"
                                   FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Kích thước khóa:" Style="{StaticResource LblField}"
                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ComboBox x:Name="cmbKeySize" Width="175" FontSize="13"
                                      SelectedIndex="0" VerticalAlignment="Center"
                                      Padding="6,4" BorderBrush="#90A4AE">
                                <ComboBoxItem Content="256-bit (Demo nhanh)"/>
                                <ComboBoxItem Content="512-bit (Khuyến nghị)"/>
                                <ComboBoxItem Content="1024-bit (An toàn cao)"/>
                            </ComboBox>
                            <Button Content="⚙ Tạo Khóa" x:Name="btnGenerateKeys"
                                    Style="{StaticResource BtnPrimary}"
                                    Click="BtnGenerateKeys_Click" Margin="14,0,0,0"/>
                            <Button Content="💾 Lưu Cặp Khóa" x:Name="btnSaveKeys" 
                                    Style="{StaticResource BtnTransfer}" 
                                    Click="BtnSaveKeys_Click" Margin="14,0,0,0"/>
                            <TextBlock x:Name="txtKeyStatus" VerticalAlignment="Center"
                                       Margin="14,0,0,0" FontStyle="Italic" Foreground="#78909C"/>
                        </StackPanel>

                        <Border Background="#E3F2FD" CornerRadius="7" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📢 THAM SỐ CÔNG KHAI (q, a, Y_A)"
                                           FontWeight="Bold" Foreground="#1565C0" FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Text="q — Số nguyên tố lớn (Mô-đun):" Style="{StaticResource LblField}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtQ" Height="58" Style="{StaticResource TxtReadonly}"/>
                                    <Button Grid.Column="1" Content="📋" ToolTip="Sao chép"
                                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                                            Click="CopyQ_Click"/>
                                </Grid>

                                <TextBlock Text="a — Căn nguyên thủy mod q:" Style="{StaticResource LblField}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtA" Height="34" Style="{StaticResource TxtReadonly}"/>
                                    <Button Grid.Column="1" Content="📋" ToolTip="Sao chép"
                                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                                            Click="CopyA_Click"/>
                                </Grid>

                                <TextBlock Text="Y_A — Khóa công khai (Y_A = a^X_A mod q):" Style="{StaticResource LblField}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtYA" Height="58" Style="{StaticResource TxtReadonly}"/>
                                    <Button Grid.Column="1" Content="📋" ToolTip="Sao chép"
                                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                                            Click="CopyYA_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#FCE4EC" CornerRadius="7" Padding="16">
                            <StackPanel>
                                <TextBlock Text="🔒 KHÓA BÍ MẬT (X_A)"
                                           FontWeight="Bold" Foreground="#B71C1C" FontSize="13" Margin="0,0,0,6"/>
                                <TextBlock Text="⚠ Không được chia sẻ khóa này với bất kỳ ai!"
                                           Foreground="#E53935" FontStyle="Italic" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock Text="X_A — Khóa riêng tư (Private Key):" Style="{StaticResource LblField}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtXA" Height="58" Style="{StaticResource TxtReadonly}"/>
                                    <Button Grid.Column="1" Content="📋" ToolTip="Sao chép"
                                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                                            Click="CopyXA_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem FontSize="13" FontWeight="SemiBold" Padding="12,6">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✍" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="Ký Số"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,16">
                        <TextBlock Text="Tạo chữ ký số cho thông điệp" FontSize="15"
                                   FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,14"/>

                        <TextBlock Text="📝 Thông điệp cần ký (M):" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtMsgSign" Height="85"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 FontSize="13" BorderBrush="#90A4AE" Padding="8"
                                 VerticalScrollBarVisibility="Auto" Background="White"/>

                        <TextBlock Text="# Giá trị băm SHA-256 (Dạng số nguyên):"
                                   Style="{StaticResource LblField}" Foreground="#5C6BC0"/>
                        <TextBox x:Name="txtSignHash" Height="34" Style="{StaticResource TxtReadonly}"
                                 Foreground="#5C6BC0"/>

                        <Button Content="✍ Ký Thông Điệp" x:Name="btnSign"
                                Style="{StaticResource BtnPrimary}"
                                Click="BtnSign_Click"
                                HorizontalAlignment="Center" Margin="0,14,0,14"/>

                        <Border Background="#E8F5E9" CornerRadius="7" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="📜 CHỮ KÝ SỐ (r, s)"
                                           FontWeight="Bold" Foreground="#2E7D32" FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Text="r = a^k mod q:" Style="{StaticResource LblField}"/>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtSignR" Height="58" Style="{StaticResource TxtReadonly}"/>
                                    <Button Grid.Column="1" Content="📋"
                                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                                            Click="CopyR_Click"/>
                                </Grid>

                                <TextBlock Grid.Row="3" Text="s = k⁻¹ · (M − X_A·r) mod (q−1):" Style="{StaticResource LblField}"/>
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtSignS" Height="58" Style="{StaticResource TxtReadonly}"/>
                                    <Button Grid.Column="1" Content="📋"
                                            Style="{StaticResource BtnSecondary}" Margin="6,0,0,0"
                                            Click="CopyS_Click"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Separator Margin="0,12"/>

                        <Grid>
                            <Button Content="💾 Lưu Chữ Ký Số (.sig)" x:Name="btnSaveSignature"
                                    Style="{StaticResource BtnTransfer}"
                                    Click="BtnSaveSignature_Click"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem FontSize="13" FontWeight="SemiBold" Padding="12,6">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="14" Margin="0,0,5,0"/>
                        <TextBlock Text="Xác Thực"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22,16">
                        <TextBlock Text="Xác thực tính toàn vẹn của thông điệp" FontSize="15"
                                   FontWeight="Bold" Foreground="#1565C0" Margin="0,0,0,6"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <Button Content="📂 Nạp Khóa Công Khai (.pub)" Style="{StaticResource BtnSecondary}" Click="BtnLoadPublicKey_Click" Margin="0,0,14,0"/>
                            <Button Content="📂 Nạp File Chữ Ký (.sig)" Style="{StaticResource BtnSecondary}" Click="BtnLoadSignatureFile_Click"/>
                        </StackPanel>

                        <TextBlock Text="📝 Thông điệp cần xác thực:" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtMsgVerify" Height="85"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 FontSize="13" BorderBrush="#90A4AE" Padding="8"
                                 VerticalScrollBarVisibility="Auto" Background="White"/>

                        <TextBlock Text="r (Thành phần chữ ký):" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtVerifyR" Height="58"
                                 FontFamily="Consolas" FontSize="11"
                                 TextWrapping="Wrap" BorderBrush="#90A4AE"
                                 Padding="6" Background="White"/>

                        <TextBlock Text="s (Thành phần chữ ký):" Style="{StaticResource LblField}"/>
                        <TextBox x:Name="txtVerifyS" Height="58"
                                 FontFamily="Consolas" FontSize="11"
                                 TextWrapping="Wrap" BorderBrush="#90A4AE"
                                 Padding="6" Background="White"/>

                        <Button Content="🔍 Xác Thực Chữ Ký" x:Name="btnVerify"
                                Style="{StaticResource BtnPrimary}"
                                Click="BtnVerify_Click"
                                HorizontalAlignment="Left" Margin="0,14,0,14"/>

                        <Border Background="#F5F5F5" CornerRadius="7" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="📊 CHI TIẾT KIỂM TRA"
                                           FontWeight="Bold" Foreground="#37474F" FontSize="13" Margin="0,0,0,10"/>

                                <TextBlock Text="M (Mã băm SHA-256 BigInteger):" Style="{StaticResource LblField}" Foreground="#5C6BC0"/>
                                <TextBox x:Name="txtVHash" Height="34" Style="{StaticResource TxtReadonly}"
                                         Foreground="#5C6BC0"/>

                                <TextBlock Text="Vế trái: V1 = a^M mod q:" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtVLHS" Height="58" Style="{StaticResource TxtReadonly}"/>

                                <TextBlock Text="Vế phải: V2 = (Y_A^r · r^s) mod q:" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtVRHS" Height="58" Style="{StaticResource TxtReadonly}"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="borderResult" CornerRadius="8" Padding="20" Background="#ECEFF1">
                            <TextBlock x:Name="txtResult"
                                       FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Foreground="#78909C" Text="— Chưa xác thực —"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>