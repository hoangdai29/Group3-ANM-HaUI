<Window x:Class="Elgamal_Signature_CS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chữ Ký Số ElGamal — Nhóm 3 ANM-HaUI"
        Height="680" Width="960"
        MinHeight="650" MinWidth="920"
        MaxHeight="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenHeight}}"
        MaxWidth="{Binding Source={x:Static SystemParameters.MaximizedPrimaryScreenWidth}}"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- ===== WINDOW CONTROLS ===== -->
        <Style x:Key="WindowControlBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#606060"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                    <Setter Property="Foreground" Value="#0066CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowCloseBtn" TargetType="Button" BasedOn="{StaticResource WindowControlBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4444"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== BUTTON STYLES ===== -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0066CC"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#0066CC" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0052A3"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D0D0D0"/>
                    <Setter Property="Foreground" Value="#808080"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#E8F0F8"/>
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#99CCFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0066CC"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#0052A3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button">
            <Setter Property="Background" Value="#00A85C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00A85C" BlurRadius="6" ShadowDepth="0" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#008A4A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D0D0D0"/>
                    <Setter Property="Foreground" Value="#808080"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background" Value="#CC3333"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#AA2222"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== TEXTBOX: Editable ===== -->
        <Style x:Key="TxtEditable" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="CaretBrush" Value="#0066CC"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Courier New"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="SelectionBrush" Value="#99CCFF"/>
        </Style>

        <!-- ===== TEXTBOX: Readonly ===== -->
        <Style x:Key="TxtReadonly" TargetType="TextBox">
            <Setter Property="Background" Value="#F9F9F9"/>
            <Setter Property="Foreground" Value="#009966"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Code, Courier New"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="BorderBrush" Value="#DCDCDC"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- ===== LABELS ===== -->
        <Style x:Key="LblField" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#0066CC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Margin" Value="0,4,0,12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- ===== TAB ITEMS ===== -->
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Padding" Value="22,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#F0F0F0"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1,1,1,0"
                                Margin="2,0,2,0"
                                CornerRadius="5,5,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#0066CC"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#0052A3"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#0066CC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main border -->
    <Border BorderBrush="#DCDCDC" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== TITLE BAR ===== -->
            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DCDCDC" BorderThickness="0,0,0,2"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,10,20,10">
                        <Border Background="#0066CC" CornerRadius="7" Width="36" Height="36" Margin="0,0,12,0">
                            <TextBlock Text="🔐" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CHỮ KÝ SỐ ELGAMAL" FontSize="17" FontWeight="Black"
                                       Foreground="#1A1A1A" FontFamily="Segoe UI"/>
                            <TextBlock Text="ELGAMAL DIGITAL SIGNATURE SYSTEM" FontSize="10"
                                       FontWeight="SemiBold" Foreground="#0066CC" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                HorizontalAlignment="Left" Margin="10,0,0,0">
                        <Border Background="#F0F0F0" CornerRadius="5" Padding="12,5" Margin="0,0,8,0"
                                BorderBrush="#0066CC" BorderThickness="1.5">
                            <TextBlock x:Name="txtHeaderKeyStatus" Text="⬤  CHƯA KHỞI TẠO KHÓA"
                                       Foreground="#CC3333" FontSize="11" FontWeight="Black" FontFamily="Segoe UI"/>
                        </Border>
                        <Border Background="#F0F0F0" CornerRadius="5" Padding="12,5" BorderBrush="#CCCCCC" BorderThickness="1.5">
                            <TextBlock Text="Nhóm 3 · ANM-HaUI" Foreground="#666666" FontSize="11" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Content="─" Style="{StaticResource WindowControlBtn}" Click="BtnMinimize_Click" ToolTip="Thu nhỏ"/>
                        <Button x:Name="btnMaximize" Content="🗖" Style="{StaticResource WindowControlBtn}"
                                Click="BtnMaximize_Click" ToolTip="Phóng to / Thu nhỏ"/>
                        <Button Content="✕" Style="{StaticResource WindowCloseBtn}" Click="BtnClose_Click" ToolTip="Đóng"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== TAB CONTROL ===== -->
            <TabControl Grid.Row="1" x:Name="tabMain" Background="#F5F5F5"
                        BorderThickness="0,2,0,0" BorderBrush="#DCDCDC" Margin="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel">
                        <Setter Property="Background" Value="#FFFFFF"/>
                    </Style>
                </TabControl.Resources>

                <!-- ===== TAB 1: TẠO KHÓA ===== -->
                <TabItem Style="{StaticResource TabItemStyle}" Header="🔑  TẠO KHÓA">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
                        <Grid Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cột trái -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="⚙️ CẤU HÌNH SINH KHÓA TỰ ĐỘNG"/>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="18" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Kích thước khóa bảo mật:" Style="{StaticResource LblField}"
                                                   Foreground="#333333" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="cmbKeySize" Background="#FFFFFF" Foreground="#1A1A1A"
                                                  BorderBrush="#0066CC" BorderThickness="2" Padding="10,8"
                                                  SelectedIndex="1" FontSize="13" FontWeight="Bold">
                                            <ComboBoxItem Content="256-bit  (Demo — Siêu nhanh)"/>
                                            <ComboBoxItem Content="512-bit  (Chuẩn thuật toán)"/>
                                            <ComboBoxItem Content="1024-bit (Độ an toàn cao nhất)"/>
                                        </ComboBox>
                                        <Button Content="⚡  BẮT ĐẦU TỰ ĐỘNG SINH KHÓA"
                                                x:Name="btnGenerateKeys" Style="{StaticResource BtnPrimary}"
                                                Click="BtnGenerateKeys_Click" Margin="0,16,0,0"
                                                HorizontalAlignment="Stretch" Height="42"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource SectionHeader}" Text="📝 CẤU HÌNH THỦ CÔNG"/>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="18" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Điền trực tiếp các giá trị q, a, X_A vào bảng bên phải rồi kích hoạt nút bên dưới để tự tính Y_A."
                                                   Foreground="#444444" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>
                                        <Button Content="📐  ÁP DỤNG THÔNG SỐ THỦ CÔNG"
                                                x:Name="btnApplyManual" Style="{StaticResource BtnDanger}"
                                                Click="BtnApplyManual_Click" HorizontalAlignment="Stretch" Height="38"/>
                                    </StackPanel>
                                </Border>

                                <!-- Trạng thái khóa -->
                                <Border x:Name="borderKeyStatus" Background="#FFF0F0" CornerRadius="6"
                                        Padding="14,10" BorderBrush="#FF9999" BorderThickness="2">
                                    <TextBlock x:Name="txtKeyStatus" FontSize="12.5" FontWeight="Bold"
                                               Foreground="#CC3333" FontFamily="Segoe UI" TextWrapping="Wrap"
                                               Text="HỆ THỐNG GIÁM SÁT: Chưa có cặp khóa active trong phiên làm việc."/>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                    <Button Content="💾  LƯU CẶP KHÓA VỀ MÁY (.PUB / .PRI)"
                                            x:Name="btnSaveKeys" Style="{StaticResource BtnSuccess}"
                                            Click="BtnSaveKeys_Click" IsEnabled="False" Height="38"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Cột phải -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="📢 GIÁ TRỊ CHI TIẾT CÁC THAM SỐ KHÓA"/>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="18" BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="q — Số nguyên tố lớn (Modulus):" Style="{StaticResource LblField}"/>
                                        <TextBox x:Name="txtQ" Height="62" Style="{StaticResource TxtEditable}"
                                                 TextChanged="Txt_ClearError" LostFocus="TxtQ_LostFocus"/>
                                        <TextBlock x:Name="errQ" Foreground="#CC3333" FontSize="11"
                                                   Margin="0,3,0,6" Visibility="Collapsed" TextWrapping="Wrap"
                                                   Background="#FFE0E0" Padding="6,3"/>

                                        <TextBlock Text="α (Alpha) — Căn nguyên thủy (Generator):" Style="{StaticResource LblField}"/>
                                        <TextBox x:Name="txtA" Height="38" Style="{StaticResource TxtEditable}"
                                                 TextChanged="Txt_ClearError" LostFocus="TxtA_LostFocus"/>
                                        <TextBlock x:Name="errA" Foreground="#CC3333" FontSize="11"
                                                   Margin="0,3,0,6" Visibility="Collapsed" TextWrapping="Wrap"
                                                   Background="#FFE0E0" Padding="6,3"/>

                                        <TextBlock Text="X_A — Khóa bí mật dùng để ký (Private Key)  ⚠️ Bảo mật nghiêm ngặt:"
                                                   Style="{StaticResource LblField}" Foreground="#FF8C00"/>
                                        <TextBox x:Name="txtXA" Height="62" Style="{StaticResource TxtEditable}"
                                                 BorderBrush="#FF8C00" Background="#FFFBF0"
                                                 Foreground="#333333"
                                                 TextChanged="Txt_ClearError" LostFocus="TxtXA_LostFocus"/>
                                        <TextBlock x:Name="errXA" Foreground="#CC3333" FontSize="11"
                                                   Margin="0,3,0,6" Visibility="Collapsed" TextWrapping="Wrap"
                                                   Background="#FFE0E0" Padding="6,3"/>

                                        <TextBlock Text="Y_A — Khóa công khai dùng để xác thực (Public Key):"
                                                   Style="{StaticResource LblField}" Foreground="#009966"/>
                                        <TextBox x:Name="txtYA" Height="62" Style="{StaticResource TxtReadonly}"
                                                 BorderBrush="#00CC99" Background="#F0FFF8"
                                                 Foreground="#009966"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== TAB 2: KÝ SỐ ===== -->
                <TabItem Style="{StaticResource TabItemStyle}" Header="✍️  KÝ SỐ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
                        <Grid Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cột trái -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="📄 NGUỒN DỮ LIỆU ĐẦU VÀO ĐỂ KÝ"/>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="PHƯƠNG THỨC 1: Tải tệp tin hệ thống (Ảnh / Văn bản PDF)"
                                                   Foreground="#333333" FontWeight="Bold" FontSize="12.5" Margin="0,0,0,12"/>
                                        <WrapPanel>
                                            <Button Content="🖼️  Tải Ảnh (.png/.jpg)" x:Name="btnLoadImageSign"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Click="BtnLoadImageSign_Click" Margin="0,0,10,8"/>
                                            <Button Content="📋  Tải tài liệu PDF" x:Name="btnLoadPdfSign"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Click="BtnLoadPdfSign_Click" Margin="0,0,0,8"/>
                                        </WrapPanel>

                                        <Border x:Name="borderFilePreviewSign" Background="#E8F0FF" CornerRadius="6"
                                                Padding="12,10" Margin="0,10,0,0" BorderBrush="#0066CC"
                                                BorderThickness="2" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="txtFileIconSign" Text="📄" FontSize="26"
                                                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="txtFileNameSign" Foreground="#1A1A1A"
                                                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="txtFileSizeSign" Foreground="#0066CC"
                                                               FontSize="11" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock x:Name="txtFileHashSign" Foreground="#009966" FontSize="11.5"
                                                   FontWeight="Bold" Margin="0,8,0,0" FontFamily="Consolas"
                                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="PHƯƠNG THỨC 2: Ký chuỗi thông điệp hoặc số nguyên trực tiếp:"
                                           Foreground="#444444" FontSize="12" FontWeight="Bold" Margin="0,4,0,8"/>

                                <TextBlock Text="Nội dung thông điệp M (văn bản hoặc số nguyên):"
                                           Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtMsgSign" Height="80" Style="{StaticResource TxtEditable}"/>

                                <TextBlock Style="{StaticResource LblField}" Foreground="#FF8C00">
                                    <Run Text="Số ngẫu nhiên ký k"/>
                                    <Run Text="  (Điều kiện: 1 &lt; k &lt; q-1 và GCD(k, q-1) = 1 · Bỏ trống → tự động sinh)"/>
                                </TextBlock>
                                <TextBox x:Name="txtKInput" Height="36" Style="{StaticResource TxtEditable}"
                                         BorderBrush="#FF8C00" Background="#FFFBF0" Foreground="#333333"/>

                                <TextBlock Text="Giá trị băm số học (hash) thực tế đưa vào tính toán ký:"
                                           Style="{StaticResource LblField}" Foreground="#009966"/>
                                <TextBox x:Name="txtSignHash" Height="36" Style="{StaticResource TxtReadonly}"/>

                                <Button Content="✍️  THỰC HIỆN KÝ SỐ ĐIỆN TỬ"
                                        x:Name="btnSign" Style="{StaticResource BtnPrimary}"
                                        Click="BtnSign_Click" HorizontalAlignment="Stretch"
                                        Margin="0,16,0,0" Height="42"/>
                            </StackPanel>

                            <!-- Cột phải -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="📜 CHỮ KÝ SỐ ĐẦU RA (KẾT QUẢ TOÁN HỌC)"/>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="18" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Thành phần chữ ký r  (r = αᵏ mod q):"
                                                   Style="{StaticResource LblField}" Foreground="#009966"/>
                                        <TextBox x:Name="txtSignR" Height="38" Style="{StaticResource TxtReadonly}"
                                                 BorderBrush="#00CC99" Foreground="#009966" Background="#F0FFF8"/>

                                        <TextBlock Text="Thành phần chữ ký s  (s = k⁻¹ · (M − X_A·r) mod (q−1)):"
                                                   Style="{StaticResource LblField}" Foreground="#009966"/>
                                        <TextBox x:Name="txtSignS" Height="38" Style="{StaticResource TxtReadonly}"
                                                 BorderBrush="#00CC99" Foreground="#009966" Background="#F0FFF8"/>

                                        <TextBlock Text="Khối chữ ký gộp (SIG_BLOCK preview):"
                                                   Style="{StaticResource LblField}"/>
                                        <TextBox x:Name="txtSignatureBlock" Height="46" Style="{StaticResource TxtReadonly}"
                                                 Foreground="#0066CC" FontWeight="Black" Background="#E8F0FF"
                                                 BorderBrush="#0066CC"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#E8F0FF" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                        BorderBrush="#0066CC" BorderThickness="1.5">
                                    <StackPanel>
                                        <TextBlock Text="ĐIỀU HƯỚNG DỮ LIỆU NHANH" Foreground="#0066CC"
                                                   FontSize="12" FontWeight="Black" Margin="0,0,0,8"/>
                                        <Button Content="→  Chuyển toàn bộ dữ liệu ký sang Tab Xác Thực công khai"
                                                x:Name="btnTransferToVerify" Style="{StaticResource BtnSecondary}"
                                                Click="BtnTransferToVerify_Click" HorizontalAlignment="Stretch"
                                                IsEnabled="False" Height="38"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="💾  XUẤT FILE CHỮ KÝ (.SIG)"
                                        x:Name="btnSaveSignature" Style="{StaticResource BtnSuccess}"
                                        Click="BtnSaveSignature_Click" HorizontalAlignment="Right"
                                        IsEnabled="False" Height="38"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== TAB 3: XÁC THỰC ===== -->
                <TabItem Style="{StaticResource TabItemStyle}" Header="✅  XÁC THỰC CHỮ KÝ">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
                        <Grid Margin="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cột trái -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="📂 NẠP THÔNG TIN KIỂM CHỨNG CHỨNG THƯ"/>

                                <Border Background="#F9F9F9" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Nạp các văn bản chữ ký từ bên ngoài:"
                                                   Foreground="#333333" FontWeight="Bold" FontSize="12.5" Margin="0,0,0,12"/>
                                        <WrapPanel>
                                            <Button Content="🔑  Nạp Khóa công khai (.pub)"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Click="BtnLoadPublicKey_Click" Margin="0,0,10,8"/>
                                            <Button Content="📄  Nạp Chữ Ký gốc (.sig)"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Click="BtnLoadSignatureFile_Click" Margin="0,0,0,8"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="#F9F9F9" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Tải tệp tin cần kiểm tra toàn vẹn:"
                                                   Foreground="#333333" FontWeight="Bold" FontSize="12.5" Margin="0,0,0,12"/>
                                        <WrapPanel>
                                            <Button Content="🖼️  Tải Ảnh kiểm chứng"
                                                    x:Name="btnLoadImageVerify" Style="{StaticResource BtnSecondary}"
                                                    Click="BtnLoadImageVerify_Click" Margin="0,0,10,8"/>
                                            <Button Content="📋  Tải PDF kiểm chứng"
                                                    x:Name="btnLoadPdfVerify" Style="{StaticResource BtnSecondary}"
                                                    Click="BtnLoadPdfVerify_Click" Margin="0,0,0,8"/>
                                        </WrapPanel>

                                        <Border x:Name="borderFilePreviewVerify" Background="#E8F0FF" CornerRadius="6"
                                                Padding="12,10" Margin="0,10,0,0" BorderBrush="#0066CC"
                                                BorderThickness="2" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="txtFileIconVerify" Text="📄" FontSize="26"
                                                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock x:Name="txtFileNameVerify" Foreground="#1A1A1A"
                                                               FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                                                    <TextBlock x:Name="txtFileSizeVerify" Foreground="#0066CC"
                                                               FontSize="11" FontWeight="Bold"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock x:Name="txtFileHashVerify" Foreground="#009966" FontSize="11.5"
                                                   FontWeight="Bold" Margin="0,8,0,0" FontFamily="Consolas"
                                                   TextWrapping="Wrap" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Hoặc kiểm tra thông điệp văn bản / số nhập tay:"
                                           Foreground="#444444" FontSize="12" FontWeight="Bold" Margin="0,4,0,8"/>

                                <TextBlock Text="Nội dung thông điệp M cần kiểm tra toàn vẹn:" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtMsgVerify" Height="80" Style="{StaticResource TxtEditable}"/>

                                <TextBlock Text="Thành phần chữ ký số r:" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtVerifyR" Height="36" Style="{StaticResource TxtEditable}"/>

                                <TextBlock Text="Thành phần chữ ký số s:" Style="{StaticResource LblField}"/>
                                <TextBox x:Name="txtVerifyS" Height="36" Style="{StaticResource TxtEditable}"/>

                                <Button Content="🔍  KÍCH HOẠT XÁC THỰC CHỮ KÝ"
                                        x:Name="btnVerify" Style="{StaticResource BtnPrimary}"
                                        Click="BtnVerify_Click" HorizontalAlignment="Stretch"
                                        Margin="0,16,0,0" Height="42"/>
                            </StackPanel>

                            <!-- Cột phải: kết quả -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionHeader}" Text="📊 PHÂN TÍCH SO SÁNH VÀ KẾT QUẢ ĐỐI CHIẾU"/>
                                <Border Background="#F9F9F9" CornerRadius="8" Padding="18" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="2">
                                    <StackPanel>
                                        <TextBlock Text="Giá trị đại diện số học M đưa vào toán học:"
                                                   Style="{StaticResource LblField}"/>
                                        <TextBox x:Name="txtVHash" Height="36" Style="{StaticResource TxtReadonly}"/>

                                        <TextBlock Text="Vế trái:   V₁ = αᴹ mod q"
                                                   Style="{StaticResource LblField}" Foreground="#0066CC"/>
                                        <TextBox x:Name="txtVLHS" Height="36" Style="{StaticResource TxtReadonly}"
                                                 Foreground="#0066CC" BorderBrush="#99CCFF" Background="#E8F0FF"/>

                                        <TextBlock Text="Vế phải:  V₂ = (Y_A^r · r^s) mod q"
                                                   Style="{StaticResource LblField}" Foreground="#FF8C00"/>
                                        <TextBox x:Name="txtVRHS" Height="36" Style="{StaticResource TxtReadonly}"
                                                 Foreground="#FF8C00" BorderBrush="#FFD9A3" Background="#FFFBF0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Kết quả xác thực -->
                                <Border x:Name="borderResult" CornerRadius="10" Padding="24"
                                        Background="#F5F5F5" BorderBrush="#DCDCDC" BorderThickness="3">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtResultIcon" Text="⏳" FontSize="46"
                                                   HorizontalAlignment="Center" Margin="0,0,0,14"/>
                                        <TextBlock x:Name="txtResult" FontSize="15" FontWeight="Black"
                                                   HorizontalAlignment="Center" TextAlignment="Center"
                                                   Foreground="#666666" Text="— ĐANG CHỜ DỮ LIỆU XÁC THỰC —"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Ghi chú toán học -->
                                <Border Background="#F0FFF8" CornerRadius="6" Padding="14,10" Margin="0,16,0,0"
                                        BorderBrush="#99FFCC" BorderThickness="1.5">
                                    <TextBlock Foreground="#009966" FontSize="11.5" FontFamily="Segoe UI"
                                               TextWrapping="Wrap" LineHeight="19">
                                        <Run Text="📌 Nguyên lý: " FontWeight="Bold" Foreground="#009966"/>
                                        <Run Text="Chữ ký hợp lệ khi và chỉ khi V₁ = V₂. Bất kỳ thay đổi nào trên thông điệp M, chữ ký (r, s), hoặc khóa Y_A đều khiến hai vế không bằng nhau."/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== TAB 4: HƯỚNG DẪN ===== -->
                <TabItem Style="{StaticResource TabItemStyle}" Header="📘  HƯỚNG DẪN">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
                        <Grid Margin="30,24,30,24">
                            <StackPanel>
                                <TextBlock Text="QUY TRÌNH VẬN HÀNH HỆ THỐNG CHỮ KÝ SỐ ELGAMAL"
                                           FontSize="18" FontWeight="Black" Foreground="#0066CC" Margin="0,0,0,4"/>
                                <TextBlock Text="Tài liệu hướng dẫn thực hành và kiểm thử — Học phần An Toàn Bảo Mật Thông Tin"
                                           FontSize="12" FontStyle="Italic" Foreground="#666666" Margin="0,0,0,20"/>

                                <Border BorderBrush="#DCDCDC" BorderThickness="0,0,0,1" Margin="0,0,0,16"/>

                                <TextBlock Text="PHẦN I: KHỞI TẠO KHÓA (KEY GENERATION)"
                                           FontSize="14" FontWeight="Bold" Foreground="#009966" Margin="0,8,0,8"/>
                                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource HelpText}">
                                            <Run Text="👉 Chế độ tự động (Khuyến nghị): " FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text="Tại Tab 'TẠO KHÓA', chọn kích thước bit (mặc định 512-bit). Nhấn nút "/>
                                            <Run Text="⚡ BẮT ĐẦU TỰ ĐỘNG SINH KHÓA" FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text=". Hệ thống tự tìm số nguyên tố an toàn (Safe Prime) q, căn nguyên thủy α, chọn ngẫu nhiên X_A và tính Y_A."/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource HelpText}" Margin="0">
                                            <Run Text="👉 Chế độ nhập tay (Giải đề bài): " FontWeight="Bold" Foreground="#FF8C00"/>
                                            <Run Text="Nhập thủ công q, α (a), X_A vào bảng bên phải rồi nhấn "/>
                                            <Run Text="📐 ÁP DỤNG THÔNG SỐ THỦ CÔNG" FontWeight="Bold" Foreground="#CC3333"/>
                                            <Run Text=". Hệ thống tự tính Y_A = α^(X_A) mod q."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="PHẦN II: TẠO CHỮ KÝ SỐ (SIGNING PROCESS)"
                                           FontSize="14" FontWeight="Bold" Foreground="#009966" Margin="0,8,0,8"/>
                                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,16"
                                        BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource HelpText}">
                                            <Run Text="Bước 1: " FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text="Chuyển sang Tab 'KÝ SỐ'. Tải file (Ảnh/PDF) hoặc nhập văn bản/số nguyên M."/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource HelpText}">
                                            <Run Text="Bước 2 (Tùy chọn): " FontWeight="Bold" Foreground="#FF8C00"/>
                                            <Run Text="Nếu đề yêu cầu k cụ thể, nhập vào ô k. Bỏ trống → hệ thống tự chọn k hợp lệ."/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource HelpText}" Margin="0">
                                            <Run Text="Bước 3: " FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text="Nhấn "/>
                                            <Run Text="✍️ THỰC HIỆN KÝ SỐ ĐIỆN TỬ" FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text=". Cặp chữ ký (r, s) xuất hiện. Nhấn 'Chuyển sang Tab Xác Thực' hoặc xuất .sig."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="PHẦN III: XÁC THỰC CHỮ KÝ SỐ (VERIFICATION)"
                                           FontSize="14" FontWeight="Bold" Foreground="#009966" Margin="0,8,0,8"/>
                                <Border Background="#F9F9F9" CornerRadius="6" Padding="16" Margin="0,0,0,8"
                                        BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource HelpText}">
                                            <Run Text="Trường hợp 1 (Liên tuyến từ Tab Ký Số): " FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text="Dùng nút điều hướng nhanh, toàn bộ dữ liệu tự điền. Chỉ cần nhấn "/>
                                            <Run Text="🔍 KÍCH HOẠT XÁC THỰC" FontWeight="Bold" Foreground="#0066CC"/>
                                            <Run Text="."/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource HelpText}">
                                            <Run Text="Trường hợp 2 (File độc lập): " FontWeight="Bold" Foreground="#FF8C00"/>
                                            <Run Text="Nạp .pub (khóa công khai), nạp .sig (chữ ký), rồi tải lại tệp cần kiểm chứng."/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource HelpText}" Margin="0">
                                            <Run Text="⚠️ Lưu ý quan trọng: " FontWeight="Bold" Foreground="#FF8C00"/>
                                            <Run Text="Khoảng trắng trong văn bản là một phần nội dung đã ký. Thêm hoặc xóa bất kỳ ký tự nào — kể cả dấu cách — đều bị phát hiện ngay."/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource HelpText}" Margin="0">
                                            <Run Text="🎯 Nguyên lý: " FontWeight="Bold" Foreground="#333333"/>
                                            <Run Text="So sánh V₁ = αᴹ mod q với V₂ = (Y_A^r · r^s) mod q. "/>
                                            <Run Text="V₁ = V₂ → ✅ HỢP LỆ" FontWeight="Bold" Foreground="#009966"/>
                                            <Run Text=",  V₁ ≠ V₂ → "/>
                                            <Run Text="❌ THẤT BẠI" FontWeight="Bold" Foreground="#CC3333"/>
                                            <Run Text="."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- ===== STATUS BAR ===== -->
            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DCDCDC" BorderThickness="0,2,0,0">
                <Grid Margin="18,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtStatusBar" Text="Hệ thống đã sẵn sàng làm việc."
                               Foreground="#444444" FontSize="11.5" FontWeight="SemiBold"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Grid.Column="1" Text="ELGAMAL CORE ENGINE v2.6 · SHA-256 · ANM-HaUI"
                               Foreground="#999999" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
