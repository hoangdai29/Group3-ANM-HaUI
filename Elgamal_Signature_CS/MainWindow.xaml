                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtStatusBar" Text="Hệ thống đã sẵn sàng làm việc." Foreground="#FFFFFF" FontSize="11.5" FontWeight="Bold" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                <TextBlock Grid.Column="1" Text="ELGAMAL CORE ENGINE v2.5 · SECURE HASH SHA-256" Foreground="#6688A5" FontSize="11.5" FontWeight="Bold" VerticalAlignment="Center" FontFamily="Segoe UI"/>
            </Grid>
        </Border>
    </Grid>
</Window>