<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="650.0" minWidth="1100.0" prefHeight="720.0" prefWidth="1200.0" styleClass="root-pane" xmlns="http://javafx.scene.com/javafx/17" xmlns:fx="http://javafx.scene.com/fxml/1" fx:controller="vn.haui.elgamal.controller.MainController">
    <top>
        <VBox alignment="CENTER" prefHeight="72.0" styleClass="header-banner" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
            <children>
                <Label text="HỆ THỐNG CHỮ KÝ SỐ ELGAMAL" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Label text="Bài thực nghiệm môn An Ninh Mạng - Trường Công nghệ thông tin - HaUI" textFill="#e0e7ff">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
            </children>
        </VBox>
    </top>

    <center>
        <HBox spacing="15.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" styleClass="step-scroll-pane">
                    <content>
                        <VBox prefWidth="380.0" styleClass="step-card">
                            <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" styleClass="card-header keygen-header">
                            <padding>
                                <Insets left="15.0" />
                            </padding>
                            <children>
                                <Label text="BƯỚC 1: TẠO KHÓA" textFill="#4338ca">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Độ dài khóa:">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="cbBitLength" prefWidth="100.0" />
                                        <Button fx:id="btnAutoKey" mnemonicParsing="false" onAction="#handleAutoKeyGen" styleClass="btn btn-primary" text="Sinh tự động" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnManualMode" mnemonicParsing="false" onAction="#toggleManualMode" styleClass="btn btn-secondary" text="Nhập thủ công" />
                                        <ProgressIndicator fx:id="progressKeyGen" managed="false" prefHeight="25.0" prefWidth="25.0" visible="false" />
                                    </children>
                                </HBox>

                                <VBox fx:id="vboxManualInput" managed="false" spacing="5.0" visible="false">
                                    <children>
                                        <Label text="Số nguyên tố p (Hệ 10):" />
                                        <TextField fx:id="tfManualP" promptText="Ví dụ: 98436402..." />
                                        <Label fx:id="lblErrorP" managed="false" styleClass="lbl-error" text="p phải là số nguyên tố" visible="false" />

                                        <Label text="Căn nguyên thủy alpha (Hệ 10):" />
                                        <TextField fx:id="tfManualAlpha" promptText="Ví dụ: 2, 3, 5..." />
                                        <Label fx:id="lblErrorAlpha" managed="false" styleClass="lbl-error" text="alpha không phải căn nguyên thủy" visible="false" />

                                        <Label text="Khóa bí mật x (Hệ 10):" />
                                        <TextField fx:id="tfManualX" promptText="Ví dụ: 12345 (1 &lt; x &lt; p-1)" />
                                        <Label fx:id="lblErrorX" managed="false" styleClass="lbl-error" text="x không nằm trong khoảng hợp lệ" visible="false" />

                                        <Button fx:id="btnApplyManualKey" mnemonicParsing="false" onAction="#handleApplyManualKey" styleClass="btn btn-secondary" text="Áp dụng khóa" />
                                    </children>
                                </VBox>

                                <GridPane hgap="8.0" vgap="8.0" VBox.vgrow="ALWAYS">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="NEVER" maxWidth="82.0" minWidth="72.0" prefWidth="82.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                        <ColumnConstraints hgrow="NEVER" maxWidth="56.0" minWidth="56.0" prefWidth="56.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints vgrow="ALWAYS" />
                                        <RowConstraints vgrow="ALWAYS" />
                                        <RowConstraints vgrow="ALWAYS" />
                                        <RowConstraints vgrow="ALWAYS" />
                                    </rowConstraints>
                                    <children>
                                        <Label styleClass="key-label" text="p:" GridPane.rowIndex="0">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextArea fx:id="taKeyP" editable="false" prefHeight="54.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Button mnemonicParsing="false" onAction="#copyP" styleClass="btn-copy" text="Copy" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                                        <Label styleClass="key-label" text="alpha:" GridPane.rowIndex="1">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextArea fx:id="taKeyAlpha" editable="false" prefHeight="54.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Button mnemonicParsing="false" onAction="#copyAlpha" styleClass="btn-copy" text="Copy" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                                        <Label styleClass="key-label" text="x (Private):" GridPane.rowIndex="2">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextArea fx:id="taKeyX" editable="false" prefHeight="54.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Button mnemonicParsing="false" onAction="#copyX" styleClass="btn-copy" text="Copy" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                                        <Label styleClass="key-label" text="y (Public):" GridPane.rowIndex="3">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextArea fx:id="taKeyY" editable="false" prefHeight="54.0" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Button mnemonicParsing="false" onAction="#copyY" styleClass="btn-copy" text="Copy" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>

                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnLoadKeys" mnemonicParsing="false" onAction="#handleLoadKeyFromFile" styleClass="btn btn-secondary" text="Nạp khóa từ file" HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnSaveKeys" mnemonicParsing="false" onAction="#handleSaveKeys" styleClass="btn btn-primary" text="Lưu khóa ra file" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <VBox prefWidth="380.0" styleClass="step-card" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" styleClass="card-header sign-header">
                            <padding>
                                <Insets left="15.0" />
                            </padding>
                            <children>
                                <Label text="BƯỚC 2: KÝ TÀI LIỆU" textFill="#1d4ed8">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Nguồn dữ liệu:">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="cbSignSourceType" onAction="#handleSignSourceTypeChange" prefWidth="165.0" />
                                    </children>
                                </HBox>

                                <VBox fx:id="vboxSignText" spacing="5.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Văn bản trực tiếp:" />
                                        <TextArea fx:id="taSignInput" prefHeight="130.0" promptText="Nhập văn bản cần ký tại đây..." wrapText="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                                <VBox fx:id="vboxSignFile" managed="false" spacing="8.0" visible="false" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Chọn tệp tin để ký (.pdf, .docx, .txt,...):" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnSelectSignFile" mnemonicParsing="false" onAction="#handleSelectSignFile" styleClass="btn btn-secondary" text="Chọn file..." />
                                                <Label fx:id="lblSignFilePath" text="Chưa chọn file nào." wrapText="true" HBox.hgrow="ALWAYS">
                                                    <padding>
                                                        <Insets top="5.0" />
                                                    </padding>
                                                    <font>
                                                        <Font name="System Italic" size="12.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </HBox>
                                        <Label styleClass="lbl-info" text="* Hệ thống ký trên toàn bộ byte dữ liệu của file, không chỉ phần văn bản hiển thị." wrapText="true">
                                            <font>
                                                <Font name="System Italic" size="11.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnSign" mnemonicParsing="false" onAction="#handleSign" prefWidth="150.0" styleClass="btn btn-info" text="Ký tài liệu" />
                                        <ProgressIndicator fx:id="progressSign" managed="false" prefHeight="25.0" prefWidth="25.0" visible="false" />
                                    </children>
                                </HBox>

                                <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Chữ ký đầu ra (r_base64|s_base64):">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextArea fx:id="taSignOutput" editable="false" prefHeight="110.0" promptText="Chữ ký số sẽ hiển thị ở đây sau khi ký..." wrapText="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                                <HBox spacing="10.0">
                                    <children>
                                        <Button fx:id="btnSaveSignature" mnemonicParsing="false" onAction="#handleSaveSignature" styleClass="btn btn-info" text="Lưu chữ ký (.sig)" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox prefWidth="380.0" styleClass="step-card" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" styleClass="card-header verify-header">
                            <padding>
                                <Insets left="15.0" />
                            </padding>
                            <children>
                                <Label text="BƯỚC 3: XÁC MINH CHỮ KÝ" textFill="#065f46">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Nguồn dữ liệu:">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="cbVerifySourceType" onAction="#handleVerifySourceTypeChange" prefWidth="165.0" />
                                    </children>
                                </HBox>

                                <VBox fx:id="vboxVerifyText" spacing="5.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Văn bản cần kiểm tra:" />
                                        <TextArea fx:id="taVerifyInput" prefHeight="85.0" promptText="Nhập hoặc dán văn bản cần xác minh..." wrapText="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                                <VBox fx:id="vboxVerifyFile" managed="false" spacing="8.0" visible="false" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Chọn tệp tin cần kiểm tra:" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnSelectVerifyFile" mnemonicParsing="false" onAction="#handleSelectVerifyFile" styleClass="btn btn-secondary" text="Chọn file..." />
                                                <Label fx:id="lblVerifyFilePath" text="Chưa chọn file nào." wrapText="true" HBox.hgrow="ALWAYS">
                                                    <padding>
                                                        <Insets top="5.0" />
                                                    </padding>
                                                    <font>
                                                        <Font name="System Italic" size="12.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Chữ ký (Paste hoặc chọn file .sig):" />
                                        <HBox spacing="8.0">
                                            <children>
                                                <TextArea fx:id="taVerifySignature" prefHeight="52.0" promptText="Dán r_base64|s_base64..." wrapText="true" HBox.hgrow="ALWAYS" />
                                                <Button fx:id="btnSelectSigFile" mnemonicParsing="false" onAction="#handleSelectSigFile" prefHeight="52.0" styleClass="btn-copy" text="Tệp .sig" />
                                            </children>
                                        </HBox>

                                        <Label text="Khóa công khai y (Hệ 10):" />
                                        <TextArea fx:id="taVerifyPubY" prefHeight="52.0" promptText="Nhập y (hoặc tự động nhận từ Bước 1)..." wrapText="true" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnVerify" mnemonicParsing="false" onAction="#handleVerify" prefWidth="150.0" styleClass="btn btn-success" text="Xác minh chữ ký" />
                                        <ProgressIndicator fx:id="progressVerify" managed="false" prefHeight="25.0" prefWidth="25.0" visible="false" />
                                    </children>
                                </HBox>

                                <VBox fx:id="vboxResultCard" alignment="CENTER" prefHeight="78.0" styleClass="result-card-default" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label fx:id="lblVerifyResult" text="Chưa thực hiện xác minh" textAlignment="CENTER" wrapText="true">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>

    <bottom>
        <VBox spacing="5.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="5.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="LỊCH SỬ HÀNH ĐỘNG">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnClearLog" mnemonicParsing="false" onAction="#handleClearLog" styleClass="btn-copy" text="Xóa lịch sử" />
                        <Button fx:id="btnResetAll" mnemonicParsing="false" onAction="#handleResetAll" styleClass="btn-copy" text="Reset toàn bộ hệ thống" />
                    </children>
                </HBox>
                <ListView fx:id="lvLogs" prefHeight="115.0" styleClass="log-list-view" />
            </children>
        </VBox>
    </bottom>
</BorderPane>